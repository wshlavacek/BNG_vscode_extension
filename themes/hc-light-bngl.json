{
	"$schema": "vscode://schemas/color-theme",
	"type": "hc-light-bngl",
	"colors": {
		"editor.background": "#ffffff",
		"editor.foreground": "#000000",
		"editorIndentGuide.activeBackground": "#333333",
		"editorIndentGuide.background": "#999999"
	},
	"tokenColors": [
		{
			"scope": [
				"meta.embedded",
				"source.groovy.embedded"
			],
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"scope": "comment",
			"settings": {
				"foreground": "#008000"
			}
		},
		{
			"scope": "constant.language",
			"settings": {
				"foreground": "#0000CC"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"variable.other.enummember",
				"keyword.operator.plus.exponent",
				"keyword.operator.minus.exponent"
			],
			"settings": {
				"foreground": "#006600"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#CC0000"
			}
		},
		{
			"scope": "storage",
			"settings": {
				"foreground": "#0000CC"
			}
		},
		{
			"scope": [
				"string",
				"meta.embedded.assembly"
			],
			"settings": {
				"foreground": "#990000"
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#0000CC"
			}
		},
		{
			"scope": "keyword.control",
			"settings": {
				"foreground": "#990099"
			}
		},
		{
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function"
			],
			"settings": {
				"foreground": "#664400"
			}
		},
		{
			"scope": [
				"support.class",
				"support.type",
				"entity.name.type",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#006666"
			}
		},
		{
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"support.variable",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#000066"
			}
		},
		{
			"scope": "keyword.other.species.tag.bngl",
			"settings": {
				"foreground": "#CC0000"
			}
		},
		{
			"scope": "keyword.control.species.compartment.bngl",
			"settings": {
				"foreground": "#660099"
			}
		},
		{
			"scope": "constant.numeric.species.mod.bngl",
			"settings": {
				"foreground": "#666600"
			}
		},
		{
			"scope": "variable.parameter.state.name.bngl",
			"settings": {
				"foreground": "#666600"
			}
		},
		{
			"scope": "meta.molecule.name.bngl",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"scope": "meta.component.name.bngl",
			"settings": {
				"foreground": "#006600"
			}
		},
		{
			"scope": "variable.parameter.tag.name.bngl",
			"settings": {
				"foreground": "#CC0000"
			}
		},
		{
			"scope": "variable.parameter.compartment.name.bngl",
			"settings": {
				"foreground": "#CC0000"
			}
		},
		{
			"scope": "constant.language.compartment.symbol.bngl",
			"settings": {
				"foreground": "#006655"
			}
		},
		{
			"scope": "constant.language.tag.symbol.bngl",
			"settings": {
				"foreground": "#006655"
			}
		},
		{
			"scope": "variable.parameter.bond.name.bngl",
			"settings": {
				"foreground": "#006600"
			}
		},
		{
			"scope": "entity.name.section",
			"settings": {
				"foreground": "#664400"
			}
		},
		{
			"scope": "meta.block_tag.name.bngl",
			"settings": {
				"foreground": "#990000"
			}
		},
		{
			"scope": "meta.block_tag.mod.bngl",
			"settings": {
				"foreground": "#660099"
			}
		},
		{
			"scope": "variable.parameter.action_argument.argument_value",
			"settings": {
				"foreground": "#556600"
			}
		},
		{
			"scope": "meta.species.null_pat",
			"settings": {
				"foreground": "#CC0000"
			}
		},
		{
			"scope": "variable.language.function.argument.bngl",
			"settings": {
				"foreground": "#006600"
			}
		},
		{
			"scope": "punctuation.separator.continuation.line.bngl",
			"settings": {
				"foreground": "#CC0000"
			}
		},
		{
			"scope": "punctuation.line.continue.bngl",
			"settings": {
				"foreground": "#006600"
			}
		},
		{
			"scope": [
				"punctuation.action.arguments.begin_brace.bngl",
				"punctuation.action.arguments.end_brace.bngl"
			],
			"settings": {
				"foreground": "#336600"
			}
		},
		{
			"scope": [
				"punctuation.action.arguments.begin_paran.bngl",
				"punctuation.action.arguments.end_paran.bngl"
			],
			"settings": {
				"foreground": "#664400"
			}
		},
		{
			"scope": "meta.moleculetype.name.bngl",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"scope": "meta.action.name.bngl",
			"settings": {
				"foreground": "#000000"
			}
		},
		{
			"scope": "variable.parameter.reaction.reactants.bngl",
			"settings": {
				"foreground": "#006600",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "variable.parameter.reaction.products.bngl",
			"settings": {
				"foreground": "#556600",
				"fontStyle": "bold"
			}
		}
	]
}
