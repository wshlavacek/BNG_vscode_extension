{
	"$schema": "vscode://schemas/color-theme",
	"type": "hc-dark-bngl",
	"colors": {
		"editor.background": "#000000",
		"editor.foreground": "#ffffff",
		"editorIndentGuide.activeBackground": "#c0c0c0",
		"editorIndentGuide.background": "#666666"
	},
	"tokenColors": [
		{
			"scope": [
				"meta.embedded",
				"source.groovy.embedded"
			],
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"scope": "comment",
			"settings": {
				"foreground": "#7CA668"
			}
		},
		{
			"scope": "constant.language",
			"settings": {
				"foreground": "#569CD6"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"variable.other.enummember",
				"keyword.operator.plus.exponent",
				"keyword.operator.minus.exponent"
			],
			"settings": {
				"foreground": "#B5CEA8"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#FF6666"
			}
		},
		{
			"scope": "storage",
			"settings": {
				"foreground": "#569CD6"
			}
		},
		{
			"scope": [
				"string",
				"meta.embedded.assembly"
			],
			"settings": {
				"foreground": "#CE9178"
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#569CD6"
			}
		},
		{
			"scope": "keyword.control",
			"settings": {
				"foreground": "#C586C0"
			}
		},
		{
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function"
			],
			"settings": {
				"foreground": "#DCDCAA"
			}
		},
		{
			"scope": [
				"support.class",
				"support.type",
				"entity.name.type",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#4EC9B0"
			}
		},
		{
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"support.variable",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#9CDCFE"
			}
		},
		{
			"scope": "keyword.other.species.tag.bngl",
			"settings": {
				"foreground": "#FF6666"
			}
		},
		{
			"scope": "keyword.control.species.compartment.bngl",
			"settings": {
				"foreground": "#B39DDB"
			}
		},
		{
			"scope": "constant.numeric.species.mod.bngl",
			"settings": {
				"foreground": "#FFFF00"
			}
		},
		{
			"scope": "variable.parameter.state.name.bngl",
			"settings": {
				"foreground": "#FFFF00"
			}
		},
		{
			"scope": "meta.molecule.name.bngl",
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"scope": "meta.component.name.bngl",
			"settings": {
				"foreground": "#66FF88"
			}
		},
		{
			"scope": "variable.parameter.tag.name.bngl",
			"settings": {
				"foreground": "#FF8888"
			}
		},
		{
			"scope": "variable.parameter.compartment.name.bngl",
			"settings": {
				"foreground": "#FF8888"
			}
		},
		{
			"scope": "constant.language.compartment.symbol.bngl",
			"settings": {
				"foreground": "#66DDBB"
			}
		},
		{
			"scope": "constant.language.tag.symbol.bngl",
			"settings": {
				"foreground": "#66DDBB"
			}
		},
		{
			"scope": "variable.parameter.bond.name.bngl",
			"settings": {
				"foreground": "#88EE88"
			}
		},
		{
			"scope": "entity.name.section",
			"settings": {
				"foreground": "#DDBB77"
			}
		},
		{
			"scope": "meta.block_tag.name.bngl",
			"settings": {
				"foreground": "#FF8888"
			}
		},
		{
			"scope": "meta.block_tag.mod.bngl",
			"settings": {
				"foreground": "#B39DDB"
			}
		},
		{
			"scope": "variable.parameter.action_argument.argument_value",
			"settings": {
				"foreground": "#CCDD44"
			}
		},
		{
			"scope": "meta.species.null_pat",
			"settings": {
				"foreground": "#FF6666"
			}
		},
		{
			"scope": "variable.language.function.argument.bngl",
			"settings": {
				"foreground": "#00FF88"
			}
		},
		{
			"scope": "punctuation.separator.continuation.line.bngl",
			"settings": {
				"foreground": "#FF0000"
			}
		},
		{
			"scope": "punctuation.line.continue.bngl",
			"settings": {
				"foreground": "#66FF88"
			}
		},
		{
			"scope": [
				"punctuation.action.arguments.begin_brace.bngl",
				"punctuation.action.arguments.end_brace.bngl"
			],
			"settings": {
				"foreground": "#88BB66"
			}
		},
		{
			"scope": [
				"punctuation.action.arguments.begin_paran.bngl",
				"punctuation.action.arguments.end_paran.bngl"
			],
			"settings": {
				"foreground": "#DDBB77"
			}
		},
		{
			"scope": "meta.moleculetype.name.bngl",
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"scope": "meta.action.name.bngl",
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"scope": "variable.parameter.reaction.reactants.bngl",
			"settings": {
				"foreground": "#66FF88",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "variable.parameter.reaction.products.bngl",
			"settings": {
				"foreground": "#CCDD44",
				"fontStyle": "bold"
			}
		}
	]
}
