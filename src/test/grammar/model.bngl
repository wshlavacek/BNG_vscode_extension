# SYNTAX TEST "source.bngl" "full model structure"

begin model
# <-- entity.name.section.model.bngl

begin parameters
# <-- entity.name.section.parameters.bngl
  k1  1.0
# ^^ variable.other.constant.bngl
end parameters

begin molecule types
# <-- entity.name.section.moleculetypes.bngl
  A(s~u~p)
# ^ meta.moleculetype.name.bngl
end molecule types

begin observables
# <-- entity.name.section.observables.bngl
  Molecules Obs_A A()
# ^^^^^^^^^ variable.language.observable.type.bngl
end observables

begin reaction rules
# <-- entity.name.section.rules.bngl
  0 -> A() k1
#   ^^ keyword.control.rule.unidir.bngl
end reaction rules

end model
# <-- entity.name.section.model.bngl

generate_network({overwrite=>1})
#^^^^^^^^^^^^^^^ meta.action.name.bngl
simulate({method=>"ode",t_end=>100,n_steps=>200})
#^^^^^^^ meta.action.name.bngl
