{
    "publisher": "als251",
    "repository": {
        "type": "git",
        "url": "https://github.com/RuleWorld/BNG_vscode_extension"
    },
    "homepage": "https://github.com/RuleWorld/BNG_vscode_extension#readme",
    "bugs": {
        "url": "https://github.com/RuleWorld/BNG_vscode_extension/issues"
    },
    "icon": "assets/flagman.png",
    "galleryBanner": {
        "color": "#C80000",
        "theme": "dark"
    },
    "name": "bngl",
    "displayName": "BioNetGen Language",
    "description": "BNG language extension for vscode",
    "version": "0.8.2",
    "engines": {
        "vscode": "^1.82.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets",
        "Themes"
    ],
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build": "node esbuild.js",
        "compile": "npm run check-types && node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package": "npm run check-types && node esbuild.js --production",
        "check-types": "tsc --noEmit",
        "test:prepare": "tsc -p . && node esbuild.js",
        "test": "npm run test:extension",
        "test:all": "npm test && npm run test:grammar",
        "test:extension": "npm run test:prepare && node ./out/test/runTest.js",
        "test:grammar": "npx vscode-tmgrammar-test -g syntaxes/bngl.tmLanguage.json \"src/test/grammar/*.bngl\""
    },
    "main": "./dist/extension.js",
    "extensionDependencies": [
        "ms-python.python"
    ],
    "activationEvents": [
        "onCommand:bng.results_folder",
        "onCommand:bng.setup",
        "onCommand:bng.upgrade",
        "onCommand:bng.menu",
        "onLanguage:bngl"
    ],
    "contributes": {
        "languages": [
            {
                "id": "bngl",
                "aliases": [
                    "BioNetGen Language",
                    "bng"
                ],
                "extensions": [
                    ".bngl",
                    ".net",
                    ".gdat",
                    ".cdat",
                    ".scan"
                ],
                "configuration": "./bngl-language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "bngl",
                "scopeName": "source.bngl",
                "path": "./syntaxes/bngl.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "bngl",
                "path": "./snippets/bngl-snippets.json"
            }
        ],
        "themes": [
            {
                "label": "dark-bngl",
                "uiTheme": "vs-dark",
                "path": "./themes/dark-bngl.json"
            },
            {
                "label": "light-bngl",
                "uiTheme": "vs",
                "path": "./themes/light-bngl.json"
            },
            {
                "label": "hc-dark-bngl",
                "uiTheme": "hc-black",
                "path": "./themes/hc-dark-bngl.json"
            },
            {
                "label": "hc-light-bngl",
                "uiTheme": "hc-light",
                "path": "./themes/hc-light-bngl.json"
            }
        ],
        "commands": [
            {
                "command": "bng.menu",
                "title": "BioNetGen",
                "icon": {
                    "dark": "./assets/flagman.png",
                    "light": "./assets/flagman.png"
                }
            },
            {
                "command": "bng.run_bngl",
                "title": "BNG: Run Simulation"
            },
            {
                "command": "bng.run_contactmap",
                "title": "BNG: Visualize Contact Map"
            },
            {
                "command": "bng.run_viz",
                "title": "BNG: Visualize All Graphs"
            },
            {
                "command": "bng.results_folder",
                "title": "BNG: Results Folder..."
            },
            {
                "command": "bng.webview",
                "title": "BNG: Open Plot / Viewer"
            },
            {
                "command": "bng.setup",
                "title": "BNG: Install/Check PyBioNetGen"
            },
            {
                "command": "bng.upgrade",
                "title": "BNG: Upgrade"
            },
            {
                "command": "bng.process_cleanup",
                "title": "BNG: Kill All Processes"
            },
            {
                "command": "bng.kill_process",
                "title": "Kill process"
            }
        ],
        "views": {
            "explorer": [
                {
                    "id": "processManagerTreeView",
                    "name": "BNG Process Manager",
                    "when": "bng.processManagerActive"
                }
            ]
        },
        "menus": {
            "editor/title": [
                {
                    "when": "resourceLangId == bngl || resourceExtname == .gdat || resourceExtname == .cdat || resourceExtname == .scan || resourceExtname == .graphml || activeWebviewPanelId == plot",
                    "group": "navigation",
                    "command": "bng.menu"
                }
            ],
            "view/item/context": [
                {
                    "when": "view == processManagerTreeView",
                    "command": "bng.kill_process"
                }
            ],
            "commandPalette": [
                {
                    "command": "bng.kill_process",
                    "when": "false"
                },
                {
                    "command": "bng.process_cleanup",
                    "when": "bng.processManagerActive"
                },
                {
                    "command": "bng.results_folder",
                    "when": "resourceLangId == bngl && resourceExtname == .bngl"
                }
            ]
        },
        "keybindings": [
            {
                "command": "bng.run_bngl",
                "key": "ctrl+shift+f1",
                "mac": "cmd+shift+f1",
                "when": "resourceLangId == bngl && resourceExtname == .bngl"
            },
            {
                "command": "bng.run_contactmap",
                "key": "ctrl+shift+f2",
                "mac": "cmd+shift+f2",
                "when": "resourceLangId == bngl && resourceExtname == .bngl"
            },
            {
                "command": "bng.webview",
                "key": "ctrl+shift+f1",
                "mac": "cmd+shift+f1",
                "when": "resourceExtname == .gdat || resourceExtname == .cdat || resourceExtname == .scan"
            }
        ],
        "configuration": {
            "title": "BioNetGen",
            "properties": {
                "bngl.general.auto_install": {
                    "markdownDescription": "Enable or disable automated install of PyBioNetGen.",
                    "type": "boolean",
                    "default": true
                },
                "bngl.general.enable_terminal_runner": {
                    "markdownDescription": "Enable old terminal runner for model running and visualization.",
                    "type": "boolean",
                    "default": false
                },
                "bngl.general.auto_open": {
                    "markdownDescription": "(WIP) Enable or disable automated opening of result files like gdat.",
                    "type": "boolean",
                    "default": true
                },
                "bngl.general.result_folder": {
                    "markdownDescription": "Base folder for generated results. When unset, results are written beside the active model in `results_<model>/<timestamp>/`. Relative paths resolve from the workspace folder, or from the model folder when no workspace is open.",
                    "type": [
                        "string",
                        "null"
                    ],
                    "default": null,
                    "scope": "resource"
                },
                "bngl.plotting.legend": {
                    "markdownDescription": "To plot the legend or not with built-in plotting",
                    "type": "boolean",
                    "default": true
                },
                "bngl.plotting.max_series_count": {
                    "markdownDescription": "The number of maximum time series to plot.",
                    "type": "number",
                    "default": 50,
                    "minimum": 1
                }
            }
        }
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.5.0",
        "@types/vscode": "1.82.0",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.5",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "typescript": "^6.0.2",
        "vscode-tmgrammar-test": "^0.1.3"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    }
}
